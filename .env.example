# Supabase configuration for SVGMaker accounts / cloud features.
#
# Copy this file to `.env.local` (gitignored via the `*.local` rule) and fill in
# the values from your Supabase project: Dashboard → Project Settings → API.
#
# These are safe to expose in the client bundle — the anon key is *designed* to
# be public. Security comes from Row-Level Security policies on the database,
# not from keeping this key secret.
#
# Leave these unset and the app runs exactly as before, with all account
# features disabled (no client is created, no network calls are made).
#
# On Cloudflare Pages, set the same two variables under
# Settings → Environment variables (Production + Preview).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
